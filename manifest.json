{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "4v4WarsWatcher",
    "version": "0.1.0.0",
    "minimum-overwolf-version": "0.220.0",
    "author": "HeyMicheal",
    "description": "TFT 4v4 観戦用オーバーレイアプリ",
    "icon": "img/icons/icon_256.png",
    "icon_gray": "img/icons/icon_256.png"
  },
  "permissions": [
    "GameInfo",
    "GameEvents"
  ],
  "data": {
    "start_window": "background",
    "game_targeting": {
      "type": "dedicated",
      "game_ids": [5426, 21570]
    },
    "windows": {
      "background": {
        "file": "background.html",
        "transparent": false,
        "resizable": false,
        "show_in_taskbar": false,
        "desktop_only": true,
        "size": {
          "width": 0,
          "height": 0
        }
      },
      "home": {
        "file": "home.html",
        "transparent": false,
        "resizable": false,
        "show_in_taskbar": true,
        "desktop_only": true,
        "native_window": true,
        "size": {
          "width": 780,
          "height": 600
        }
      },
      "in_game": {
        "file": "in_game.html",
        "transparent": true,
        "resizable": false,
        "show_in_taskbar": false,
        "desktop_only": false,
        "in_game_only": true,
        "size": {
          "width": 1920,
          "height": 1080
        },
        "clickthrough": true,
        "isInputPassThrough": true
      }
    },
    "game_events": [21570]
  }
}
